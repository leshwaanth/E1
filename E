pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo "Build Started"
            }
        }
    }

    post {
        success {
            mail to: 'example@gmail.com',
            subject: 'Jenkins Build Success',
            body: 'The Jenkins build completed successfully.'
